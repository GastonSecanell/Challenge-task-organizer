<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /tareas-dip/

  # Si el archivo o carpeta existe, servirlo normalmente
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Si no existe, mandar todo a index.html
  RewriteRule ^ index.html [L]
</IfModule>